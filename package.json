{
  "name": "website-intelligence-engine",
  "version": "1.0.0",
  "description": "Browser-automation based Website Intelligence Engine — crawls a company site and produces structured company intelligence.",
  "type": "module",
  "license": "MIT",
  "bin": {
    "wie": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "tsx src/cli.ts",
    "crawl": "tsx src/cli.ts",
